# --- App ---
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=            # generar con: openssl rand -base64 32

# --- Base de datos ---
# Local: Postgres en localhost. Supabase: usar las dos cadenas del panel
# (Project Settings > Database). POOLED para runtime, DIRECT para migraciones.
DATABASE_URL=postgresql://fidelizate:fidelizate@localhost:5432/fidelizate?schema=public
DIRECT_URL=postgresql://fidelizate:fidelizate@localhost:5432/fidelizate?schema=public

# Ejemplo Supabase (reemplazar [REF], [PASSWORD], [REGION]):
# DATABASE_URL=postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL=postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# --- Supabase Storage (logos de negocio) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=branding

# --- Google OAuth (opcional en local) ---
# Google Cloud Console > Credentials > OAuth client ID (Web application)
# Redirect URI local: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- GHL (opcional, solo seed demo) ---
GHL_DEMO_WEBHOOK_URL=

# --- Correo transaccional (Resend) ---
# Sin RESEND_API_KEY: modo consola (imprime el link en terminal).
RESEND_API_KEY=
EMAIL_FROM="FIDELIZATE <onboarding@resend.dev>"
APP_URL=http://localhost:3000

# --- Postgres (docker-compose) ---
POSTGRES_USER=fidelizate
POSTGRES_PASSWORD=fidelizate
POSTGRES_DB=fidelizate
